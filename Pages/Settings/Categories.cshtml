@page
@model PersonalFinanceTracker.Pages.Settings.CategoriesModel
@{
    ViewData["Title"] = "Manage Categories";
}

<div class="container-fluid py-4 settings-canvas">
    <div class="row g-4 justify-content-center">
        <!-- Add Category Section -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 glass-settings-card">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="icon-circle-badge bg-azure-soft mb-3">
                            <i class="fas fa-tags azure-text"></i>
                        </div>
                        <h5 class="fw-bold navy-text">Add New <span class="azure-text">Category</span></h5>
                    </div>

                    <form method="post">
                        <div class="mb-4">
                            <label class="form-label label-style">Category Name</label>
                            <input asp-for="NewCategory.Name" class="form-control custom-input"
                                   placeholder="e.g. Health, Gift, Debt" required />
                        </div>
                        <button type="submit" class="btn btn-navy w-100 rounded-pill fw-bold py-3 shadow-sm">
                            <i class="fas fa-plus-circle me-2"></i> Add To List
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Categories List Section -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden glass-settings-card h-100">
                <div class="card-header bg-white border-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 navy-text">Available <span class="azure-text">Categories</span></h5>
                    <span class="badge bg-azure-soft azure-text px-3 py-2 rounded-pill">Total: @Model.CategoryList.Count()</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-azure-soft">
                            <tr>
                                <th class="ps-4 py-3 azure-text small letter-spacing-1">NAME</th>
                                <th class="text-end pe-4 py-3 azure-text small letter-spacing-1">ACTION</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.CategoryList.Any())
                            {
                                foreach (var cat in Model.CategoryList)
                                {
                                    <tr class="category-row">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-circle bg-azure-soft p-2 me-3 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                                                    <i class="fas fa-tag azure-text small"></i>
                                                </div>
                                                <span class="fw-bold navy-text">@cat.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4">
                                            <form asp-page-handler="Delete" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('Delete this category?');">
                                                <button type="submit" class="btn btn-delete-sm shadow-sm">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="text-center py-5">
                                        <i class="fas fa-layer-group fa-3x text-muted opacity-25 mb-3"></i>
                                        <p class="text-muted small">No categories added yet. Start by adding one!</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --navy-deep: #0a192f;
        --azure-primary: #007bff;
        --azure-soft: #e7f1ff;
        --bg-gradient: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%);
    }

    .settings-canvas {
        background: var(--bg-gradient);
        min-height: 100vh;
    }

    .glass-settings-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .navy-text {
        color: var(--navy-deep);
    }

    .azure-text {
        color: var(--azure-primary);
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .label-style {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #6c757d;
        margin-bottom: 8px;
    }

    /* Input & Button Styling */
    .custom-input {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 12px 15px;
        transition: 0.3s;
    }

        .custom-input:focus {
            border-color: var(--azure-primary);
            box-shadow: 0 0 0 4px rgba(0, 123, 255, 0.1);
            outline: none;
        }

    .btn-navy {
        background-color: var(--navy-deep);
        color: white;
        transition: 0.3s ease;
    }

        .btn-navy:hover {
            background-color: #112240;
            color: white;
            transform: translateY(-2px);
        }

    /* Icon Badge */
    .icon-circle-badge {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .bg-azure-soft {
        background-color: var(--azure-soft);
    }

    /* Table & Row Hover */
    .category-row {
        transition: 0.2s;
    }

        .category-row:hover {
            background-color: rgba(0, 123, 255, 0.02);
        }

    /* Action Button */
    .btn-delete-sm {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: white;
        color: #dc3545;
        border: 1px solid #ffe5e5;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-delete-sm:hover {
            background: #dc3545;
            color: white;
            transform: rotate(10deg);
        }

    .rounded-4 {
        border-radius: 1.25rem !important;
    }
</style>