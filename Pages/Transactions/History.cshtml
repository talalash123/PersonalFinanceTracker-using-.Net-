@page
@model PersonalFinanceTracker.Pages.Transactions.HistoryModel

@{
    ViewData["Title"] = "Transaction History";
}

<div class="container-fluid py-4 history-canvas">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 navy-text">Financial <span class="azure-text">History</span></h2>
            <p class="text-muted small">Manage and track all your previous records.</p>
        </div>
        <a asp-page="/Transactions/Add" class="btn btn-navy rounded-pill px-4 shadow-sm fw-bold">
            <i class="fas fa-plus me-2"></i> New Transaction
        </a>
    </div>

    <!-- Main History Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden glass-panel">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-azure-soft">
                    <tr class="text-uppercase small letter-spacing-1">
                        <th class="ps-4 py-3 azure-text">Date</th>
                        <th class="py-3 azure-text">Description</th>
                        <th class="py-3 azure-text">Category</th>
                        <th class="py-3 azure-text">Amount</th>
                        <th class="text-center pe-4 py-3 azure-text">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Transactions != null && Model.Transactions.Any())
                    {
                        @foreach (var item in Model.Transactions)
                        {
                            <tr class="transaction-row">
                                <td class="ps-4 text-muted small">@item.Date.ToString("dd MMM, yyyy")</td>
                                <td class="fw-bold navy-text">@item.Description</td>
                                <td>
                                    <span class="badge rounded-pill bg-azure-light azure-text px-3 py-2">
                                        @item.Category
                                    </span>
                                </td>
                                <td class="fw-bold @(item.IsExpense ? "text-danger" : "text-success")">
                                    @(item.IsExpense ? "-" : "+") Rs. @item.Amount.ToString("N2")
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-page="/Transactions/Edit" asp-route-id="@item.Id"
                                           class="btn btn-action btn-edit shadow-sm" title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id"
                                              onsubmit="return confirm('Are you sure you want to delete this record?')">
                                            <button type="submit" class="btn btn-action btn-delete shadow-sm" title="Delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-4">
                                    <i class="fas fa-folder-open fa-3x text-muted opacity-25 mb-3"></i>
                                    <p class="text-muted fw-bold">No transactions found in your history.</p>
                                    <a asp-page="/Transactions/Add" class="btn btn-sm btn-outline-primary rounded-pill">Start Adding</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    :root {
        --navy-deep: #0a192f;
        --azure-primary: #007bff;
        --azure-light: #e7f1ff;
        --bg-gradient: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%);
    }

    .history-canvas {
        background: var(--bg-gradient);
        min-height: 100vh;
    }

    .navy-text {
        color: var(--navy-deep);
    }

    .azure-text {
        color: var(--azure-primary);
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .glass-panel {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .bg-azure-soft {
        background-color: #f8fbff;
    }

    .bg-azure-light {
        background-color: var(--azure-light);
    }

    .btn-navy {
        background-color: var(--navy-deep);
        color: white;
        transition: 0.3s ease;
    }

        .btn-navy:hover {
            background-color: #112240;
            color: white;
            transform: translateY(-2px);
        }

    /* Table & Row Styling */
    .transaction-row {
        transition: all 0.2s ease;
        border-bottom: 1px solid rgba(0,0,0,0.02);
    }

        .transaction-row:hover {
            background-color: rgba(0, 123, 255, 0.02) !important;
            transform: scale(1.002);
        }

    /* Action Buttons Styling */
    .btn-action {
        width: 36px;
        height: 36px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        border: none;
        transition: 0.3s;
    }

    .btn-edit {
        background-color: #fff;
        color: var(--azure-primary);
        border: 1px solid var(--azure-light);
    }

        .btn-edit:hover {
            background-color: var(--azure-primary);
            color: white;
        }

    .btn-delete {
        background-color: #fff;
        color: #dc3545;
        border: 1px solid #ffe5e5;
    }

        .btn-delete:hover {
            background-color: #dc3545;
            color: white;
        }

    .rounded-4 {
        border-radius: 1.25rem !important;
    }
</style>