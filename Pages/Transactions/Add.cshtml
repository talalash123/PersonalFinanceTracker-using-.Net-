@page
@model PersonalFinanceTracker.Pages.Transactions.AddModel
@{
    ViewData["Title"] = "Add Transaction";
}

<div class="container-fluid py-5 add-record-canvas">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 shadow-lg rounded-4 glass-form-card">
                <div class="card-body p-5">
                    <!-- Header Section -->
                    <div class="text-center mb-5">
                        <div class="icon-badge mb-3">
                            <i class="fas fa-plus azure-text"></i>
                        </div>
                        <h3 class="fw-bold navy-text">New <span class="azure-text">Transaction</span></h3>
                        <p class="text-muted small">Fill in the details to record your financial activity.</p>
                    </div>

                    <form method="post">
                        <div class="row g-4">
                            <!-- Description Field -->
                            <div class="col-12">
                                <label class="form-label label-style">Description</label>
                                <input asp-for="Transaction.Description"
                                       placeholder="e.g. Monthly Grocery"
                                       class="form-control custom-input" required />
                            </div>

                            <!-- Amount Field -->
                            <div class="col-md-6">
                                <label class="form-label label-style">Amount (Rs.)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-azure-soft border-0 navy-text fw-bold">Rs.</span>
                                    <input asp-for="Transaction.Amount" type="number" step="0.01"
                                           class="form-control custom-input border-start-0" required />
                                </div>
                            </div>

                            <!-- Category Dropdown -->
                            <div class="col-md-6">
                                <label class="form-label label-style">Category</label>
                                <select asp-for="Transaction.Category" class="form-select custom-input" required>
                                    <option value="">-- Select --</option>
                                    @if (Model.AvailableCategories != null)
                                    {
                                        @foreach (var cat in Model.AvailableCategories)
                                        {
                                            <option value="@cat.Name">@cat.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- Transaction Type (Styled Radio Toggles) -->
                            <div class="col-12 mt-4">
                                <label class="form-label label-style d-block mb-3">Transaction Type</label>
                                <div class="d-flex gap-3">
                                    <div class="flex-fill">
                                        <input asp-for="Transaction.IsExpense" type="radio" value="true" class="btn-check" id="exp" checked>
                                        <label class="btn btn-outline-danger w-100 rounded-3 py-3 fw-bold" for="exp">
                                            <i class="fas fa-arrow-up me-2"></i> Expense
                                        </label>
                                    </div>
                                    <div class="flex-fill">
                                        <input asp-for="Transaction.IsExpense" type="radio" value="false" class="btn-check" id="inc">
                                        <label class="btn btn-outline-success w-100 rounded-3 py-3 fw-bold" for="inc">
                                            <i class="fas fa-arrow-down me-2"></i> Income
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-5 pt-3 d-flex gap-2">
                            <button type="submit" class="btn btn-navy flex-grow-1 py-3 rounded-pill fw-bold shadow-sm">
                                <i class="fas fa-save me-2"></i> Save Transaction
                            </button>
                            <a asp-page="/Transactions/History" class="btn btn-light-azure px-4 py-3 rounded-pill border fw-bold text-muted">
                                Discard
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --navy-deep: #0a192f;
        --azure-primary: #007bff;
        --azure-soft: #e7f1ff;
        --bg-gradient: linear-gradient(135deg, #f0f4f8 0%, #d9e2ec 100%);
    }

    .add-record-canvas {
        background: var(--bg-gradient);
        min-height: 100vh;
    }

    .glass-form-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .navy-text {
        color: var(--navy-deep);
    }

    .azure-text {
        color: var(--azure-primary);
    }

    .label-style {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #6c757d;
        margin-bottom: 8px;
    }

    /* Custom Input Styling */
    .custom-input {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 12px 15px;
        transition: 0.3s;
    }

        .custom-input:focus {
            border-color: var(--azure-primary);
            box-shadow: 0 0 0 4px rgba(0, 123, 255, 0.1);
            outline: none;
        }

    .icon-badge {
        width: 60px;
        height: 60px;
        background: var(--azure-soft);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        font-size: 1.5rem;
    }

    .btn-navy {
        background-color: var(--navy-deep);
        color: white;
        transition: 0.3s ease;
    }

        .btn-navy:hover {
            background-color: #112240;
            color: white;
            transform: translateY(-2px);
        }

    .bg-azure-soft {
        background-color: var(--azure-soft);
    }

    .btn-light-azure {
        background-color: #fff;
        color: var(--navy-deep);
    }

        .btn-light-azure:hover {
            background-color: #f8fbff;
        }

    /* Radio Toggle Cards */
    .btn-check:checked + .btn-outline-danger {
        background-color: #dc3545;
        color: white;
    }

    .btn-check:checked + .btn-outline-success {
        background-color: #198754;
        color: white;
    }
</style>