<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finance Tracker</title>

    <!-- External CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #0a192f;
            --navy-light: #112240;
            --azure-primary: #007bff;
            --azure-glow: rgba(0, 123, 255, 0.15);
            --text-muted: #8892b0;
            --bg-body: #f0f4f8;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            overflow-x: hidden;
            margin: 0;
        }

        #wrapper {
            display: flex;
            width: 100%;
        }

        /* Sidebar Styling */
        #sidebar {
            min-width: 280px;
            max-width: 280px;
            background: var(--navy-deep);
            color: white;
            transition: all 0.3s ease;
            height: 100vh;
            position: fixed;
            z-index: 1000;
            box-shadow: 4px 0 15px rgba(0,0,0,0.1);
        }

        .sidebar-header {
            padding: 30px 25px;
            background: rgba(0,0,0,0.1);
        }

        .logo-text {
            font-size: 1.25rem;
            letter-spacing: 1px;
            color: white;
            text-decoration: none;
        }

        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-muted);
            padding: 25px 30px 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        /* Navigation Links */
        .nav-link {
            padding: 14px 25px;
            font-size: 0.9rem;
            color: #ccd6f6;
            display: flex;
            align-items: center;
            transition: 0.3s;
            margin: 4px 15px;
            border-radius: 12px;
            text-decoration: none;
        }

            .nav-link:hover {
                background: var(--navy-light);
                color: var(--azure-primary);
                transform: translateX(5px);
            }

            .nav-link i {
                width: 30px;
                font-size: 1.1rem;
                transition: 0.3s;
            }

            /* Active Link State */
            .nav-link.active {
                background: var(--azure-primary) !important;
                color: white !important;
                box-shadow: 0 8px 20px var(--azure-glow);
            }

                .nav-link.active i {
                    color: white !important;
                }

        /* Main Content Area */
        #content {
            width: 100%;
            padding-left: 280px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top Header inside Content */
        .top-navbar {
            background: white;
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #e2e8f0;
        }

        .main-container {
            padding: 40px;
            flex-grow: 1;
        }

        /* Responsive */
        @@media (max-width: 992px) {
            #sidebar {
                margin-left: -280px;
            }

            #content {
                padding-left: 0;
            }

            #sidebar.active {
                margin-left: 0;
            }
        }
    </style>
</head>
<body>

    <div id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header d-flex align-items-center">
                <a asp-page="/Index" class="logo-text fw-bold">
                    <i class="fas fa-chart-line text-primary me-2"></i>FT<span class="text-primary">PRO</span>
                </a>
            </div>

            <div class="mt-3">
                <div class="section-label">General</div>
                <a asp-page="/Index"
                   class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                    <i class="fas fa-home"></i> Dashboard
                </a>

                <div class="section-label">Analysis</div>
                <a asp-page="/Budgets/Progress"
                   class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString().Contains("/Budgets/") == true ? "active" : "")">
                    <i class="fas fa-rocket"></i> Spending Analysis
                </a>

                <div class="section-label">Management</div>
                <a asp-page="/Transactions/Add"
                   class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Transactions/Add" ? "active" : "")">
                    <i class="fas fa-plus-square"></i> New Entry
                </a>
                <a asp-page="/Transactions/History"
                   class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString().Contains("/Transactions/History") == true ? "active" : "")">
                    <i class="fas fa-list-ul"></i> All Activity
                </a>

                <div class="section-label">Preferences</div>
                <a asp-page="/Settings/Categories"
                   class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString().Contains("/Settings/") == true ? "active" : "")">
                    <i class="fas fa-sliders-h"></i> Settings
                </a>
            </div>
        </nav>

        <!-- Page Content -->
        <div id="content">
            <!-- Optional Top Navbar for context -->
            <header class="top-navbar shadow-sm">
                <h5 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h5>
            </header>

            <main class="main-container">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>